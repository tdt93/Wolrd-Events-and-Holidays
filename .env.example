# Optional API keys — add any combination; restart `npm run dev:api` after changes

# Holidays — Nager.Date (free) + optional enrichments below
# Festivo — city/regional holidays, 190+ languages (recommended)
# Get key: https://app.getfestivo.com/dashboard
# FESTIVO_API_KEY=your_key_here

# Calendarific — merged with Nager when key set
# CALENDARIFIC_API_KEY=your_key_here

# Ticketed events
# TICKETMASTER_API_KEY=your_key_here
# SEATGEEK_CLIENT_ID=your_client_id_here

# Football / soccer fixtures — free tier: 100 requests/day, seasons 2022–2024 only
# Get key: https://www.api-football.com/
# API_FOOTBALL_KEY=your_key_here
# API_FOOTBALL_MAX_SEASON=2024
# API_FOOTBALL_MIN_SEASON=2022

# Public site URL (share links, canonical; override for staging)
# VITE_SITE_URL=https://festseekr.tdtdev.net

# Public GitHub repo URL (shown in About panel)
# VITE_REPO_URL=https://github.com/tdt93/Wolrd-Events-and-Holidays

# API server port (default 3000)
# API_PORT=3000
